<!doctype html>
<html lang="fr">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Dashboard — SELYS AFRICA</title>
<style>
:root{
  --dark:#020707;--deep:#031314;--teal:#0f7d84;--aqua:#54ddd4;--white:#f8fffd;
  --muted:rgba(248,255,253,.70);--stroke:rgba(255,255,255,.16);--glass:rgba(255,255,255,.08);
}
*{box-sizing:border-box;margin:0;padding:0}
body{
  min-height:100vh;font-family:Inter,system-ui,-apple-system,Segoe UI,sans-serif;color:var(--white);
  background:radial-gradient(circle at 20% 0%,rgba(84,221,212,.25),transparent 30%),
  radial-gradient(circle at 90% 20%,rgba(15,125,132,.35),transparent 28%),
  linear-gradient(145deg,var(--dark),var(--deep) 55%,#062b2d);
}
header{
  display:flex;justify-content:space-between;align-items:center;
  padding:20px 32px;border-bottom:1px solid var(--stroke)
}
.header-left{display:flex;align-items:center;gap:16px}
.logo{height:36px}
.header-title{font-size:14px;font-weight:800;color:var(--aqua);letter-spacing:.08em;text-transform:uppercase}
.header-right{display:flex;align-items:center;gap:16px}
.user-name{font-size:13px;color:var(--muted)}
.logout{
  font-size:12px;color:var(--aqua);text-decoration:none;font-weight:700;
  padding:8px 16px;border:1px solid rgba(84,221,212,.3);border-radius:10px
}
.logout:hover{background:rgba(84,221,212,.1)}
.container{max-width:1000px;margin:0 auto;padding:32px 24px}
.stats{display:flex;gap:16px;margin-bottom:32px}
.stat-card{
  flex:1;padding:24px;border-radius:20px;
  border:1px solid var(--stroke);background:linear-gradient(145deg,rgba(255,255,255,.1),rgba(255,255,255,.03));
  backdrop-filter:blur(16px)
}
.stat-value{font-size:32px;font-weight:900;color:var(--aqua)}
.stat-label{font-size:12px;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;margin-top:4px}
h2{font-size:18px;margin-bottom:20px;font-weight:800}
.table-wrap{
  border:1px solid var(--stroke);border-radius:20px;overflow:hidden;
  background:linear-gradient(145deg,rgba(255,255,255,.08),rgba(255,255,255,.02));
  backdrop-filter:blur(16px)
}
table{width:100%;border-collapse:collapse}
th{
  text-align:left;padding:14px 20px;font-size:11px;font-weight:800;
  color:var(--aqua);text-transform:uppercase;letter-spacing:.1em;
  border-bottom:1px solid var(--stroke);background:rgba(0,0,0,.2)
}
td{padding:14px 20px;font-size:14px;border-bottom:1px solid rgba(255,255,255,.06)}
tr:last-child td{border-bottom:none}
tr:hover td{background:rgba(84,221,212,.04)}
.badge-exp{
  display:inline-block;padding:4px 10px;border-radius:8px;font-size:11px;font-weight:700;
  background:rgba(84,221,212,.1);color:var(--aqua);border:1px solid rgba(84,221,212,.2)
}
.view-btn{
  display:inline-block;padding:8px 16px;border-radius:10px;font-size:12px;font-weight:800;
  background:linear-gradient(135deg,var(--teal),var(--aqua));color:#031314;text-decoration:none
}
.view-btn:hover{opacity:.85}
.date{color:var(--muted);font-size:12px}
.empty{text-align:center;padding:60px 20px;color:var(--muted);font-size:15px}
@media(max-width:640px){
  .stats{flex-direction:column}
  header{flex-direction:column;gap:12px}
  th,td{padding:10px 14px;font-size:12px}
}
</style>
</head>
<body>
<header>
  <div class="header-left">
    <img class="logo" src="/logo.png" alt="SELYS AFRICA">
    <span class="header-title">Gestion des candidatures</span>
  </div>
  <div class="header-right">
    <span class="user-name">{{userName}}</span>
    <a href="/admin/logout" class="logout">Déconnexion</a>
  </div>
</header>

<div class="container">
  <div class="stats">
    <div class="stat-card">
      <div class="stat-value">{{total}}</div>
      <div class="stat-label">Candidatures reçues</div>
    </div>
  </div>

  <h2>Liste des candidatures</h2>

  {{#if applications.length}}
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Candidat</th>
          <th>Email</th>
          <th>Expérience</th>
          <th>Date</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        {{#each applications}}
        <tr>
          <td>{{this.id}}</td>
          <td style="font-weight:700">{{this.fullName}}</td>
          <td>{{this.email}}</td>
          <td><span class="badge-exp">{{this.experience}}</span></td>
          <td class="date">{{this.createdAt}}</td>
          <td><a href="/admin/candidature/{{this.id}}" class="view-btn">Voir</a></td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{else}}
  <div class="table-wrap">
    <div class="empty">Aucune candidature pour le moment.</div>
  </div>
  {{/if}}
</div>
</body>
</html>
