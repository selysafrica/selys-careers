<!doctype html>
<html lang="fr">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Connexion — SELYS AFRICA</title>
<style>
:root{
  --dark:#020707;--deep:#031314;--teal:#0f7d84;--aqua:#54ddd4;--white:#f8fffd;
  --muted:rgba(248,255,253,.70);--stroke:rgba(255,255,255,.16);
}
*{box-sizing:border-box;margin:0;padding:0}
body{
  min-height:100vh;display:flex;align-items:center;justify-content:center;
  font-family:Inter,system-ui,-apple-system,Segoe UI,sans-serif;color:var(--white);
  background:radial-gradient(circle at 20% 0%,rgba(84,221,212,.25),transparent 30%),
  radial-gradient(circle at 90% 20%,rgba(15,125,132,.35),transparent 28%),
  linear-gradient(145deg,var(--dark),var(--deep) 55%,#062b2d);
  padding:32px 16px;
}
main{width:min(420px,100%)}
.logo-wrap{text-align:center;margin-bottom:32px}
.logo{width:min(240px,60%);height:auto}
.card{
  border:1px solid var(--stroke);
  background:linear-gradient(145deg,rgba(255,255,255,.13),rgba(255,255,255,.04));
  backdrop-filter:blur(24px);border-radius:28px;padding:36px 32px;
  box-shadow:0 30px 90px rgba(0,0,0,.35)
}
h1{font-size:22px;text-align:center;margin-bottom:6px}
.sub{text-align:center;color:var(--muted);font-size:14px;margin-bottom:28px}
form{display:grid;gap:16px}
label{font-weight:800;font-size:13px;color:rgba(248,255,253,.88)}
input{
  width:100%;padding:14px 16px;border-radius:14px;border:1px solid var(--stroke);
  background:rgba(255,255,255,.07);color:var(--white);font:inherit;outline:none;font-size:14px
}
input::placeholder{color:rgba(248,255,253,.42)}
input:focus{border-color:var(--aqua)}
.btn{
  border:0;border-radius:14px;padding:15px;
  background:linear-gradient(145deg,var(--aqua),var(--teal));
  color:#031314;font-weight:950;font-size:15px;cursor:pointer;margin-top:4px
}
.btn:hover{opacity:.9}
.error-msg{
  background:rgba(255,80,80,.12);border:1px solid rgba(255,80,80,.35);
  border-radius:12px;padding:12px 16px;font-size:13px;color:#ff6b6b;text-align:center
}
</style>
</head>
<body>
<main>
  <div class="logo-wrap">
    <img class="logo" src="/logo.png" alt="SELYS AFRICA">
  </div>
  <section class="card">
    <h1>Espace Gestionnaire</h1>
    <p class="sub">Connectez-vous pour accéder aux candidatures</p>

    {{#if error}}
    <div class="error-msg">{{error}}</div>
    {{/if}}

    <form method="POST" action="/admin/login">
      <div>
        <label>Email</label>
        <input type="email" name="email" placeholder="votre@email.com" required>
      </div>
      <div>
        <label>Mot de passe</label>
        <input type="password" name="password" placeholder="Votre mot de passe" required>
      </div>
      <button class="btn" type="submit">Se connecter</button>
    </form>
  </section>
</main>

</body>
</html>
