<!doctype html>
<html lang="fr">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{#if application}}{{application.fullName}} — {{/if}}Candidature — SELYS AFRICA</title>
<style>
:root{
  --dark:#020707;--deep:#031314;--teal:#0f7d84;--aqua:#54ddd4;--white:#f8fffd;
  --muted:rgba(248,255,253,.70);--stroke:rgba(255,255,255,.16);
}
*{box-sizing:border-box;margin:0;padding:0}
body{
  min-height:100vh;font-family:Inter,system-ui,-apple-system,Segoe UI,sans-serif;color:var(--white);
  background:radial-gradient(circle at 20% 0%,rgba(84,221,212,.25),transparent 30%),
  radial-gradient(circle at 90% 20%,rgba(15,125,132,.35),transparent 28%),
  linear-gradient(145deg,var(--dark),var(--deep) 55%,#062b2d);
}
header{
  display:flex;justify-content:space-between;align-items:center;
  padding:20px 32px;border-bottom:1px solid var(--stroke)
}
.header-left{display:flex;align-items:center;gap:16px}
.logo{height:36px}
.header-title{font-size:14px;font-weight:800;color:var(--aqua);letter-spacing:.08em;text-transform:uppercase}
.header-right{display:flex;align-items:center;gap:16px}
.user-name{font-size:13px;color:var(--muted)}
.logout{
  font-size:12px;color:var(--aqua);text-decoration:none;font-weight:700;
  padding:8px 16px;border:1px solid rgba(84,221,212,.3);border-radius:10px
}
.logout:hover{background:rgba(84,221,212,.1)}
.container{max-width:800px;margin:0 auto;padding:32px 24px}
.back{
  display:inline-flex;align-items:center;gap:6px;color:var(--aqua);
  text-decoration:none;font-size:13px;font-weight:700;margin-bottom:24px
}
.back:hover{text-decoration:underline}
.card{
  border:1px solid var(--stroke);
  background:linear-gradient(145deg,rgba(255,255,255,.1),rgba(255,255,255,.03));
  backdrop-filter:blur(16px);border-radius:24px;padding:36px 32px;
  box-shadow:0 20px 60px rgba(0,0,0,.3)
}
.card-header{
  display:flex;justify-content:space-between;align-items:flex-start;
  margin-bottom:28px;padding-bottom:20px;border-bottom:1px solid var(--stroke)
}
.card-header h1{font-size:24px;font-weight:900;line-height:1.2}
.badge-exp{
  display:inline-block;padding:6px 14px;border-radius:10px;font-size:12px;font-weight:700;
  background:rgba(84,221,212,.1);color:var(--aqua);border:1px solid rgba(84,221,212,.2)
}
.section{margin-bottom:28px}
.section-title{
  font-size:13px;font-weight:800;color:var(--aqua);text-transform:uppercase;
  letter-spacing:.1em;margin-bottom:14px;
  padding-bottom:8px;border-bottom:2px solid rgba(84,221,212,.3)
}
.info-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.info-item{
  padding:14px 16px;border-radius:14px;
  background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08)
}
.info-label{font-size:11px;font-weight:700;color:var(--aqua);text-transform:uppercase;letter-spacing:.08em;margin-bottom:4px}
.info-value{font-size:14px;color:var(--white)}
.info-value a{color:var(--aqua);text-decoration:none}
.info-value a:hover{text-decoration:underline}
.cover-letter{
  padding:20px;border-radius:14px;
  background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08);
  border-left:3px solid var(--aqua);
  font-size:14px;line-height:1.75;color:rgba(248,255,253,.85);white-space:pre-wrap
}
.attachments{display:flex;gap:12px;flex-wrap:wrap}
.file-btn{
  display:inline-flex;align-items:center;gap:8px;
  padding:12px 22px;border-radius:12px;font-size:13px;font-weight:800;
  text-decoration:none;color:#fff
}
.file-btn.cv{background:linear-gradient(135deg,var(--teal),var(--aqua));color:#031314}
.file-btn.video{background:linear-gradient(135deg,#031314,var(--teal))}
.file-btn:hover{opacity:.85}
.empty{color:var(--muted);font-style:italic;font-size:14px}
.date-info{font-size:12px;color:var(--muted);margin-top:20px;text-align:right}
@media(max-width:640px){
  .info-grid{grid-template-columns:1fr}
  .card{padding:24px 20px;border-radius:20px}
  .card-header{flex-direction:column;gap:12px}
  header{flex-direction:column;gap:12px}
}
</style>
</head>
<body>
<header>
  <div class="header-left">
    <img class="logo" src="/logo.png" alt="SELYS AFRICA">
    <span class="header-title">Détail candidature</span>
  </div>
  <div class="header-right">
    <span class="user-name">{{userName}}</span>
    <a href="/admin/logout" class="logout">Déconnexion</a>
  </div>
</header>

<div class="container">
  <a href="/admin" class="back">&larr; Retour au tableau de bord</a>

  {{#if application}}
  <section class="card">
    <div class="card-header">
      <div>
        <h1>{{application.fullName}}</h1>
        <p style="color:var(--muted);font-size:13px;margin-top:4px">Directeur du Pôle Web Management</p>
      </div>
      <span class="badge-exp">{{application.experience}}</span>
    </div>

    <div class="section">
      <h2 class="section-title">Informations de contact</h2>
      <div class="info-grid">
        <div class="info-item">
          <div class="info-label">Email</div>
          <div class="info-value"><a href="mailto:{{application.email}}">{{application.email}}</a></div>
        </div>
        <div class="info-item">
          <div class="info-label">Téléphone</div>
          <div class="info-value"><a href="tel:{{application.phone}}">{{application.phone}}</a></div>
        </div>
        <div class="info-item">
          <div class="info-label">Expérience</div>
          <div class="info-value">{{application.experience}}</div>
        </div>
        <div class="info-item">
          <div class="info-label">Date de candidature</div>
          <div class="info-value">{{application.createdAt}}</div>
        </div>
      </div>
    </div>

    <div class="section">
      <h2 class="section-title">Lettre de motivation</h2>
      <div class="cover-letter">{{application.coverLetter}}</div>
    </div>

    <div class="section">
      <h2 class="section-title">Pièces jointes</h2>
      {{#if application.cvUrl}}
      <div class="attachments">
        <a href="{{application.cvUrl}}" target="_blank" class="file-btn cv">Télécharger le CV</a>
        {{#if application.videoUrl}}
        <a href="{{application.videoUrl}}" target="_blank" class="file-btn video">Visionner la vidéo</a>
        {{/if}}
      </div>
      {{else}}
      <p class="empty">Aucune pièce jointe fournie.</p>
      {{/if}}
    </div>
  </section>
  {{else}}
  <section class="card">
    <div style="text-align:center;padding:40px 20px">
      <p style="font-size:18px;font-weight:700;margin-bottom:8px">Candidature introuvable</p>
      <p style="color:var(--muted);font-size:14px">Cette candidature n'existe pas ou a été supprimée.</p>
      <a href="/admin" class="back" style="margin-top:20px;display:inline-block">&larr; Retour au tableau de bord</a>
    </div>
  </section>
  {{/if}}
</div>
</body>
</html>
