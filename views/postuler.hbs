<!doctype html>
<html lang="fr">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Postuler — Directeur Pôle Web Management | SELYS AFRICA</title>
<style>
:root{
  --dark:#020707;--deep:#031314;--teal:#0f7d84;--aqua:#54ddd4;--white:#f8fffd;
  --muted:rgba(248,255,253,.70);--stroke:rgba(255,255,255,.16);--glass:rgba(255,255,255,.08);
}
*{box-sizing:border-box}
body{
  margin:0;min-height:100vh;font-family:Inter,system-ui,-apple-system,Segoe UI,sans-serif;color:var(--white);
  background:radial-gradient(circle at 20% 0%,rgba(84,221,212,.25),transparent 30%),
  radial-gradient(circle at 90% 20%,rgba(15,125,132,.35),transparent 28%),
  linear-gradient(145deg,var(--dark),var(--deep) 55%,#062b2d);
}
main{width:min(760px,92%);margin:auto;padding:38px 0 50px}
.logo-wrap{display:flex;justify-content:center;margin:8px 0 28px}
.logo{width:min(360px,82%);height:auto}
.card{
  border:1px solid var(--stroke);background:linear-gradient(145deg,rgba(255,255,255,.13),rgba(255,255,255,.04));
  backdrop-filter:blur(24px);border-radius:34px;padding:30px;box-shadow:0 30px 90px rgba(0,0,0,.35)
}
.badge{display:inline-flex;padding:10px 14px;border-radius:999px;border:1px solid rgba(84,221,212,.28);background:rgba(84,221,212,.08);color:var(--aqua);font-size:12px;font-weight:900;letter-spacing:.14em;text-transform:uppercase}
h1{font-size:clamp(34px,6vw,58px);line-height:.95;letter-spacing:-.06em;margin:18px 0 12px;text-align:center}
.intro{color:var(--muted);font-size:16px;line-height:1.6;text-align:center;margin:0 auto 26px;max-width:620px}
form{display:grid;gap:14px;margin-top:20px}
label{font-weight:800;font-size:13px;color:rgba(248,255,253,.88)}
input,select,textarea{
  width:100%;padding:16px;border-radius:18px;border:1px solid var(--stroke);background:rgba(255,255,255,.07);
  color:var(--white);font:inherit;outline:none
}
input::placeholder,textarea::placeholder{color:rgba(248,255,253,.42)}
textarea{min-height:150px;resize:vertical}
.row{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.hint{font-size:12px;color:rgba(248,255,253,.55);margin-top:-8px}
.btn{
  border:0;border-radius:18px;padding:17px 22px;background:linear-gradient(145deg,var(--aqua),var(--teal));
  color:#031314;font-weight:950;font-size:15px;cursor:pointer;margin-top:8px;width:100%
}
.btn:disabled{opacity:.6;cursor:not-allowed}
.status{display:none;padding:14px;border-radius:16px;margin-top:6px;line-height:1.45}
.success{display:block;background:rgba(84,221,212,.12);border:1px solid rgba(84,221,212,.35)}
.error{display:block;background:rgba(255,80,80,.12);border:1px solid rgba(255,80,80,.35)}
.alt{text-align:center;color:var(--muted);font-size:13px;line-height:1.6;margin-top:20px}
.alt a{color:var(--aqua);text-decoration:none;font-weight:800}
footer{text-align:center;color:rgba(248,255,253,.48);font-size:12px;margin-top:24px}
@media(max-width:640px){.row{grid-template-columns:1fr}.card{padding:22px;border-radius:26px}}
</style>
</head>
<body>
<main>
  <div class="logo-wrap">
    <img class="logo" src="/logo.png" alt="SELYS AFRICA">
  </div>

  <section class="card">
    <div style="text-align:center"><span class="badge">Candidature · Abidjan</span></div>
    <h1>Directeur du Pôle Web Management</h1>
    <p class="intro">
      Rejoignez SELYS AFRICA pour piloter un pôle autonome dédié au Web Management, aux contenus digitaux,
      au social media, aux campagnes et aux comptes institutionnels & entreprises.
    </p>

    <form id="applicationForm" enctype="multipart/form-data">
      <div class="row">
        <div>
          <label>Nom et prénom</label>
          <input name="fullName" placeholder="Votre nom complet" required>
        </div>
        <div>
          <label>Téléphone / WhatsApp</label>
          <input name="phone" placeholder="+225 ..." required>
        </div>
      </div>

      <div class="row">
        <div>
          <label>Email</label>
          <input type="email" name="email" placeholder="votre@email.com" required>
        </div>
        <div>
          <label>Niveau d'expérience</label>
          <select name="experience" required>
            <option value="">Sélectionner</option>
            <option>3 à 5 ans</option>
            <option>5 à 8 ans</option>
            <option>8 à 12 ans</option>
            <option>Plus de 12 ans</option>
          </select>
        </div>
      </div>

      <label>Lettre de motivation</label>
      <textarea name="coverLetter" placeholder="Présentez votre parcours, votre vision du Web Management et ce que vous pouvez construire pour SELYS AFRICA." required></textarea>

      <label>CV</label>
      <input type="file" name="cv" accept=".pdf,.doc,.docx" required>
      <p class="hint">Formats acceptés : PDF, DOC, DOCX.</p>

      <label>Vidéo de présentation</label>
      <input type="file" name="video" accept="video/mp4,video/quicktime,video/webm">
      <p class="hint">Durée recommandée : 1 à 3 minutes. Formats : MP4, MOV, WEBM. Taille max : 20 Mo.</p>

      <button class="btn" type="submit" id="submitBtn">Envoyer ma candidature complète</button>
      <div id="formStatus" class="status"></div>
    </form>

    <p class="alt">
      En cas de difficulté, envoyez votre dossier à
      <a href="mailto:hi@selys-africa.com?cc=apastes@selys-africa.com&subject=Candidature%20Directeur%20P%C3%B4le%20Web%20Management">hi@selys-africa.com</a>
      avec copie à <a href="mailto:apastes@selys-africa.com">apastes@selys-africa.com</a>.<br>
      WhatsApp : <a href="https://wa.me/2250702065271">+225 07 02 06 52 71</a>
    </p>
  </section>

  <footer>SELYS AFRICA — Nos innovations vous distinguent.</footer>
</main>

<script>
const form = document.getElementById('applicationForm');
const statusBox = document.getElementById('formStatus');
const submitBtn = document.getElementById('submitBtn');

form.addEventListener('submit', async (event) => {
  event.preventDefault();

  const cvFile = form.querySelector('[name="cv"]').files[0];
  const videoFile = form.querySelector('[name="video"]').files[0];

  if (cvFile && cvFile.size > 5 * 1024 * 1024) {
    statusBox.className = 'status error';
    statusBox.textContent = 'Votre CV dépasse 5 Mo. Veuillez le compresser avant l\'envoi.';
    return;
  }
  if (videoFile && videoFile.size > 50 * 1024 * 1024) {
    statusBox.className = 'status error';
    statusBox.textContent = 'Votre vidéo dépasse 50 Mo. Veuillez la compresser ou réduire sa durée.';
    return;
  }

  submitBtn.disabled = true;
  submitBtn.textContent = 'Envoi en cours...';
  statusBox.className = 'status success';
  statusBox.textContent = 'Préparation de votre candidature...';

  try {
    let formData = new FormData(form);
    formData.append('file_cv', cvFile);
    formData.append('file_video', videoFile);
    const response = await fetch('/api/apply', {
      method: 'POST',
      body: formData,
    });

    const data = await response.json();

    if (!response.ok) throw new Error(data.message || 'Erreur serveur');

    statusBox.className = 'status success';
    statusBox.textContent = 'Candidature envoyée avec succès. Merci pour votre intérêt pour SELYS AFRICA.';
    form.reset();
  } catch (err) {
    statusBox.className = 'status error';
    statusBox.textContent = err.message || 'Erreur lors de l\'envoi. Veuillez réessayer.';
  } finally {
    submitBtn.disabled = false;
    submitBtn.textContent = 'Envoyer ma candidature complète';
  }
});
</script>
</body>
</html>
